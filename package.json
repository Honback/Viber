    "date-fns": "^4.1.0",
    "drizzle-orm": "^0.44.5",
    "lucide-react": "^0.542.0",
    "marked": "^17.0.5",
    "next": "16.2.1",
    "postgres": "^3.4.7",
    "react": "19.2.4",
