    "jobs:all": "tsx scripts/run-job.ts all",
    "jobs:recompute-ranking": "tsx scripts/recompute-ranking.ts",
    "jobs:check-links": "tsx scripts/check-links.ts",
    "jobs:cleanup-unclaimed": "tsx scripts/cleanup-unclaimed.ts",
